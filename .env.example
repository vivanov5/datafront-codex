APP_NAME=DataFront
APP_ENV=development
APP_SECRET_KEY=change-me-generate-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=720

POSTGRES_DB=datafront
POSTGRES_USER=datafront
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://datafront:change-me@postgres:5432/datafront

INITIAL_ADMIN_EMAIL=admin@datafront.local
INITIAL_ADMIN_PASSWORD=change-me-admin-password
INITIAL_ADMIN_NAME=DataFront Admin

ORACLE_DSN=oracle-host:1521/service
ORACLE_USER=oracle_user
ORACLE_PASSWORD=
ORACLE_INSTANT_CLIENT_DIR=/opt/oracle/instantclient
ORACLE_ENABLE_THICK_MODE=true

UPLOAD_ROOT=/var/lib/datafront/uploads
MAX_UPLOAD_MB=512
ALLOWED_UPLOAD_EXTENSIONS=xlsx,xls,csv,txt,zip,rar,7z

AG_GRID_LICENSE_KEY=
VITE_API_BASE_URL=/api/v1
VITE_AG_GRID_LICENSE_KEY=
